{
  "manifest_version": 2,
  "name": "NSS Communicator",
  "description": "Not So Super Sneaky — Encrypted messaging overlay for social media",
  "version": "0.1.0",
  "icons": {
    "48": "icons/nss-48-v2.png",
    "96": "icons/nss-96-v2.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/nss-48-v2.png",
      "96": "icons/nss-96-v2.png"
    },
    "default_title": "NSS Communicator",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": [
      "crypto/keys.js",
      "crypto/encrypt.js",
      "storage/keyring.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/detector.js",
        "content/injector.js"
      ],
      "css": [
        "styles/nss-inline.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nss@nexavision.tech",
      "strict_min_version": "91.0"
    }
  },
  "web_accessible_resources": [
    "content/composer.js",
    "styles/nss-inline.css",
    "styles/composer.css",
    "icons/nss-48-v2.png"
  ]
}
